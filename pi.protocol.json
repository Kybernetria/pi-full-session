{
  "protocolVersion": "0.2.0",
  "nodeId": "pi_full_session",
  "packageId": "@kybernetria/pi-full-session",
  "version": "0.1.0",
  "purpose": "Launch durable interactive Pi CLI/TUI processes in verified terminal hosts without proxying their conversation.",
  "tags": ["pi", "terminal", "worktree"],
  "provides": [
    {
      "name": "launch",
      "description": "Launch a real Pi CLI session in an existing absolute directory.",
      "effects": ["process_spawn", "file_write"],
      "policy": {"confirmation": "required"},
      "inputSchema": {"type": "object", "required": ["cwd"], "properties": {
        "cwd": {"type": "string", "description": "Existing absolute working directory."},
        "workspace": {"type": "object", "properties": {"mode": {"type": "string", "enum": ["none", "existing"]}}},
        "terminal": {"type": "string", "enum": ["stock", "term_mux"]},
        "model": {"type": "string"}, "thinking": {"type": "string", "enum": ["off", "minimal", "low", "medium", "high", "xhigh", "max"]},
        "name": {"type": "string"}, "initialPrompt": {"type": "string"},
        "handoff": {"type": "object", "properties": {"allowEffects": {"type": "boolean"}, "items": {"type": "array", "items": {"type": "object", "required": ["target", "as", "mode"], "properties": {"target": {"type": "string"}, "input": {}, "as": {"type": "string"}, "mode": {"type": "string", "enum": ["snapshot", "reference"]}, "required": {"type": "boolean"}}}}}}
      }},
      "outputSchema": {"type": "object", "required": ["launchId", "state", "piSessionId", "cwd", "terminal"], "properties": {"launchId": {"type": "string"}, "state": {"type": "string", "enum": ["launched", "ready", "working", "idle", "ended"]}, "piSessionId": {"type": "string"}, "cwd": {"type": "string"}, "branch": {"type": "string"}, "worktreePath": {"type": "string"}, "handoffId": {"type": "string"}, "terminal": {"type": "object"}}},
      "execution": {"type": "handler", "handler": "launch"}
    },
    {
      "name": "launch_worktree",
      "description": "Create a validated Git worktree and launch a real Pi CLI session there. The worktree is retained on later failure.",
      "effects": ["process_spawn", "file_write", "git_worktree"],
      "policy": {"confirmation": "required"},
      "inputSchema": {"type": "object", "required": ["cwd", "branch"], "properties": {
        "cwd": {"type": "string"}, "branch": {"type": "string"}, "destination": {"type": "string"}, "terminal": {"type": "string", "enum": ["stock", "term_mux"]},
        "model": {"type": "string"}, "thinking": {"type": "string", "enum": ["off", "minimal", "low", "medium", "high", "xhigh", "max"]}, "name": {"type": "string"}, "initialPrompt": {"type": "string"}, "handoff": {"type": "object"}
      }},
      "outputSchema": {"type": "object", "required": ["launchId", "state", "piSessionId", "worktreePath", "branch", "terminal"], "properties": {"launchId": {"type": "string"}, "state": {"type": "string"}, "piSessionId": {"type": "string"}, "worktreePath": {"type": "string"}, "branch": {"type": "string"}, "terminal": {"type": "object"}}},
      "execution": {"type": "handler", "handler": "launch_worktree"}
    },
    {"name": "status", "description": "Return the persisted launch record, latest explicit lifecycle event, and honest host status.", "inputSchema": {"type": "object", "required": ["launchId"], "properties": {"launchId": {"type": "string"}}}, "outputSchema": {"type": "object", "required": ["launchId", "state", "terminal", "hostStatus"], "properties": {"launchId": {"type": "string"}, "state": {"type": "string"}, "terminal": {"type": "object"}, "hostStatus": {}}}, "execution": {"type": "handler", "handler": "status"}},
    {"name": "focus", "description": "Focus a verified host surface when supported.", "effects": ["terminal_control"], "policy": {"confirmation": "required"}, "inputSchema": {"type": "object", "required": ["launchId"], "properties": {"launchId": {"type": "string"}}}, "outputSchema": {"type": "object", "required": ["launchId", "ok"], "properties": {"launchId": {"type": "string"}, "ok": {"type": "boolean"}}}, "execution": {"type": "handler", "handler": "focus"}},
    {"name": "send_input", "description": "Send literal input only when the selected host verifies input delivery.", "effects": ["terminal_control"], "policy": {"confirmation": "required"}, "inputSchema": {"type": "object", "required": ["launchId", "text"], "properties": {"launchId": {"type": "string"}, "text": {"type": "string"}}}, "outputSchema": {"type": "object", "required": ["launchId", "ok"], "properties": {"launchId": {"type": "string"}, "ok": {"type": "boolean"}}}, "execution": {"type": "handler", "handler": "send_input"}},
    {"name": "stop", "description": "Request graceful Pi shutdown only when the selected host advertises verified stop control.", "effects": ["terminal_control"], "policy": {"confirmation": "required"}, "inputSchema": {"type": "object", "required": ["launchId"], "properties": {"launchId": {"type": "string"}}}, "outputSchema": {"type": "object", "required": ["launchId", "ok"], "properties": {"launchId": {"type": "string"}, "ok": {"type": "boolean"}}}, "execution": {"type": "handler", "handler": "stop"}}
  ]
}
